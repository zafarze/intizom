# =========================
# БЭКЕНД (Django / Python)
# =========================
# Исключаем переменные окружения (ОЧЕНЬ ВАЖНО, чтобы не слить секретные ключи и пароли к БД!)
.env

# Исключаем виртуальное окружение
venv/
env/
.venv/

# Кэш Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Медиа файлы и статика (собираются на сервере)
media/
staticfiles/

# Локальная база данных SQLite (хоть у вас и PostgreSQL, это хорошая практика)
db.sqlite3
db.sqlite3-journal


# =========================
# ФРОНТЕНД (Node.js / React / Vite)
# =========================
# Исключаем тяжелую папку с зависимостями
frontend/node_modules/
node_modules/

# Исключаем папку сборки
frontend/dist/
frontend/dist-ssr/
dist/

# Логи npm/yarn/pnpm
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Локальные переменные окружения фронтенда
.env.local
.env.development.local
.env.test.local
.env.production.local

# Кэш Vite и eslint
frontend/.eslintcache
frontend/node_modules/.vite/


# =========================
# СРЕДЫ РАЗРАБОТКИ И ОС (Общее)
# =========================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
# Dev scripts
script.py
extract_*.py
fix_*.py
replace_*.py
translate_*.py
*.json
